	file = {Full Text PDF:C\:\\Users\\gueney\\Zotero\\storage\\R3AUH4LL\\Akcay et Jungmann - 2023 - Growth regimes, dominant social blocs and growth strategies towards varieties of export-led growth.pdf:application/pdf},
