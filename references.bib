@article{gungen_growth_2024,
	title = {Growth models, growth strategies, and power blocs in Turkey and Egypt in the twenty-first century},
	volume = {21},
	issn = {2052-7764, 2052-7772},
	url = {https://www.elgaronline.com/view/journals/ejeep/21/1/article-p151.xml},
	doi = {10.4337/ejeep.2024.01.09},
	abstract = {Analysis of the growth patterns in the Global South in the twenty-first century suggests there is room for authoritarian states to search for new growth models. Authoritarian states, such as Turkey and Egypt, benefited from global financial circumstances in the early 2000s and experienced shifts in growth strategies in the 2010s, suppressing political space further. Our main research question, thus, is focusing on what the main domestic political economy causes of these growth strategy and model changes are. To explain the changes in growth strategies and models amid the strength of reinforced authoritarian regimes in these two countries, we employ a hybrid research strategy, tying growth model changes to conflicts within the power bloc. We argue that in the mid-to-late 2010s, peripheral goods producers gained the upper hand in Turkey, while a military takeover in Egypt was followed by the promotion of exports and new investments. We also contend that power bloc reconfigurations in the last decade and the rise of new growth strategies both in Turkey and in Egypt aimed to change previous domestic demand-led demand and growth models.},
	pages = {151--171},
	number = {1},
	journaltitle = {European Journal of Economics and Economic Policies},
	publisher = {Edward Elgar Publishing Ltd},
	author = {Güngen, Ali Rıza and Akçay, Ümit},
	urldate = {2025-12-16},
	date = {2024-04-05},
	langid = {english},
	keywords = {B52, E65, Turkey, comparative political economy, growth models, E66, F43, growth strategies, O43, P52, Egypt},
	file = {Full Text PDF:C\:\\Users\\gueney\\Zotero\\storage\\8V2N8RUV\\Güngen et Akçay - 2024 - Growth models, growth strategies, and power blocs in Turkey and Egypt in the twenty-first century.pdf:application/pdf},
