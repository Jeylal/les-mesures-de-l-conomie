	file = {Full Text PDF:C\:\\Users\\gueney\\Zotero\\storage\\5N3FFWDE\\Stockhammer et Wildauer - 2016 - Debt-driven growth Wealth, distribution and demand in OECD countries.pdf:application/pdf},
}

