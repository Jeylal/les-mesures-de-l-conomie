@article{labat-moles_supermultiplier_2024,
	title = {A supermultiplier demand-led growth accounting analysis applied to the Spanish economy (1998–2019)},
	volume = {21},
	issn = {2052-7764, 2052-7772},
	url = {https://www.elgaronline.com/view/journals/ejeep/21/1/article-p42.xml},
	doi = {10.4337/ejeep.2023.0115},
	abstract = {In this paper, we analyse the demand-led determinants of Spanish economic growth from 1998–2019. We apply the supermultiplier demand-led growth accounting methodology by Freitas/Dweck (2013) with two modifications: First, we incorporate consumption out of public transfers, following Haluska et al. (2021) and Haluska (2023). Second, we incorporate consumption out of public wages as a source of autonomous demand, theoretically suggested by Serrano/Pimentel (2019). Our demand-led growth decomposition highlights: (i) public demand and exports as important stable growth drivers, and a decreasing supermultiplier that reduces growth rates; (ii) the indirect effect of a real estate boom in the economic expansion of 1998–2008 caused by increasing public revenues and opening space to the expansion of public demand; and (iii) the incapacity of exports to lead the recovery alone, as the latter started only with the resumption of the public and private demand.},
	pages = {42--72},
	number = {1},
	journaltitle = {European Journal of Economics and Economic Policies},
	publisher = {Edward Elgar Publishing Ltd},
	author = {Labat-Moles, Héctor and Summa, Ricardo},
	urldate = {2025-12-16},
	date = {2024-04-05},
	langid = {english},
	keywords = {O47, E12, E11, demand-led growth accounting, Spanish economy, supermultiplier},
	file = {Full Text PDF:C\:\\Users\\gueney\\Zotero\\storage\\U4VUPLHJ\\Labat-Moles et Summa - 2024 - A supermultiplier demand-led growth accounting analysis applied to the Spanish economy (1998–2019).pdf:application/pdf},
}

@article{campana_demand_2024,
	title = {Demand and growth regimes of the {BRICs} countries – the national income and financial accounting decomposition approach and an autonomous demand-led growth perspective},
	volume = {21},
	issn = {2052-7764, 2052-7772},
	url = {https://www.elgaronline.com/view/journals/ejeep/21/1/article-p17.xml},
	doi = {10.4337/ejeep.2023.0100},
	abstract = {We contribute to the recent debate in post-Keynesian economics ({PKE}), comparative political economy ({CPE}) and international political economy ({IPE}) on growth regimes. The paper presents an analysis of changes in demand and growth regimes in the {BRICs} countries, Brazil, Russia, India, and China, after the Global Financial Crisis and the Great Recession of 2007–2009. It discusses and applies two approaches: a first one based on national income and financial accounting decomposition and a second one based on the Sraffian Supermultiplier ({SSM}) growth model, distinguishing the dynamics of autonomous expenditure growth from those of the induced components of aggregate demand. It is argued that the {SSM} approach provides the bridge between the traditional approach based on national income and financial accounting decomposition and the analysis of growth drivers, both in {PKE} as well as in {CPE} and {IPE}. This is illustrated by pointing out some changes in the underlying political economy and economic policy growth drivers in each of the countries.},
	pages = {17--41},
	number = {1},
	journaltitle = {European Journal of Economics and Economic Policies},
	publisher = {Edward Elgar Publishing Ltd},
	author = {Campana, Juan Manuel and Vaz, João Emboava and Hein, Eckhard and Jungmann, Benjamin},
	urldate = {2025-12-16},
	date = {2024-04-05},
	langid = {english},
	keywords = {E12, E11, P16, E02, P51, demand and growth regimes, autonomous demand-led growth, growth decomposition},
	file = {Full Text PDF:C\:\\Users\\gueney\\Zotero\\storage\\ACRQHVT9\\Campana et al. - 2024 - Demand and growth regimes of the BRICs countries – the national income and financial accounting deco.pdf:application/pdf},
}

