@article{rebmann_transformation_2024,
	title = {Transformation des sommets et des frontières de l’État en Suisse au {XXème} siècle : hauts fonctionnaires, commissions extra-parlementaires et régulation des cartels},
	url = {https://iris.unil.ch/handle/iris/232780},
	shorttitle = {Transformation des sommets et des frontières de l’État en Suisse au {XXème} siècle},
	abstract = {Cette étude analyse l’évolution de l’autonomie et de la perméabilité de l’État fédéral suisse face aux intérêts particuliers au {XXe} siècle, en se concentrant sur trois axes clés : l’élite de l’administration centrale, le système des commissions extra-parlementaires ({CEP}) et l’administration de milice chargée de la régulation des cartels. À travers des approches quantitatives (prosopographie des hauts fonctionnaires et analyse d’affiliation et de réseaux des {CEP}) et qualitatives (étude des commissions de régulation des cartels entre 1926 et 1985), quatre tournants majeurs sont mis en lumière. Le premier s’établit dans les années 1920, dans un contexte où les principaux intérêts économiques assument des tâches de régulation publiques depuis la fin du {XIXe} siècle, participant ainsi à la très faible autonomie étatique. Il est marqué par l’émergence du système commissionnaliste en tant que zone intermédiaire entre le privé et le public. Ce développement représente une réponse à la grève générale de 1918 et vise à coopter le mouvement ouvrier tout en le maintenant en dehors des frontières formelles de l’État. Dans les années 1950, un second tournant voit s’établir une logique de coordination au sein du système commissionnaliste, particulièrement entre les élites syndicales et patronales. Ces mécanismes néocorporatistes se développent en grande partie en réaction à la diffusion des théories ordo et néolibérales. Cette période marque l’institutionnalisation de la faible autonomie de l’État au sein du système commissionnaliste. Le troisième tournant survient dans les années 1970, dans le contexte de la crise économique et des finances publiques. Cette période est marquée par une remise en question de la coordination néocorporatiste, provenant en particulier des acteurs académiques. Bien que cette contestation reste en grande partie non institutionnalisée, elle révèle des tensions sous-jacentes au sein des élites nationales. Enfin, dans les années 1990, nous assistons à une accélération et à une institutionnalisation partielle et inachevée de la dynamique initiée durant les années 1970. Elle est caractérisée par un renforcement partiel des frontières de l’État face aux intérêts particuliers, en partie initié par une élite administrative se rattachant de plus en plus à des principes de managérialisation. Toutefois, l’internationalisation croissante des relations étatiques limite une augmentation significative de l’autonomie de l’État fédéral. --- This study analyses the evolution of the autonomy and permeability of the Swiss federal state with regard to special interests over the course of the 20th century, focusing on three key axes: the central administration elite, the system of extraparliamentary commissions ({EPC}) and the militia administration responsible for regulating cartels. Through quantitative approaches (prosopography of senior civil servants and analysis of {EPC} affiliations and networks) and qualitative approaches (study of cartel regulation commissions between 1926 and 1985), four major turning points are highlighted. The first was established in the 1920s, in a context where the main economic interests had been assuming public regulatory tasks since the end of the 19th century, thus contributing to the very low level of state autonomy. It was marked by the emergence of the commission system as an intermediary zone between the private and public sectors. This development was a response to the 1918 general strike, and aimed to co-opt the labor movement while keeping it outside the formal boundaries of the state. In the 1950s, a second turning point saw the establishment of a logic of coordination within the commissionalist system, particularly between union and employer elites. These neo-corporatist mechanisms were developed largely in reaction to the spread of ordo and neo-liberal theories. This period marked the institutionalization of the state's limited autonomy within the commissionalist system. The third turning point came in the 1970s, against a backdrop of economic and financial crisis. This period was marked by a challenge to neo-corporatist coordination, particularly from academic players. Although this challenge remained largely non-institutionalized, it revealed underlying tensions within national elites. Finally, the 1990s saw an acceleration and partial, unfinished institutionalization of the dynamics initiated in the 1970s. This was characterized by a partial strengthening of the state’s boundaries in the face of vested interests, in part initiated by an administrative elite increasingly committed to principles of managerialization. However, the growing internationalization of state relations limits any significant increase in the autonomy of the federal state.},
	author = {Rebmann, Frédéric},
	urldate = {2026-02-19},
	date = {2024-09-25},
	langid = {french},
	file = {Full Text PDF:C\:\\Users\\gueney\\Zotero\\storage\\R29VNWUP\\Rebmann - 2024 - Transformation des sommets et des frontières de l’État en Suisse au XXème siècle  hauts fonctionnai.pdf:application/pdf},
}

@article{amable_structural_2009-1,
	title = {Structural reforms in Europe and the (in)coherence of institutions},
	volume = {25},
	issn = {0266-903X},
	url = {https://doi.org/10.1093/oxrep/grp001},
	doi = {10.1093/oxrep/grp001},
	abstract = {The aim of this paper is to analyse the consequences of some structural reforms on the institutional coherence of {OECD} countries, particularly in Continental Europe, and on their economic performance, particularly as regards employment. Because institutions in developed political economies are interrelated through a complex network of complementarities, institutional change has consequences beyond the area concerned in a reform. This also implies that there are complementarity effects in reforms themselves. A challenge of reform programmes is therefore to achieve a new type of complementarity between reformed institutions. The paper presents empirical evidence questioning the compatibility of the ongoing structural reforms in product and labour markets with the existing institutional structures in some {OECD} countries. The coherence of the flexicurity strategy, i.e. a combination of labour-market flexibility and a generous welfare state, is also questioned, from the point of view of both economic efficiency and political economy.},
	pages = {17--39},
	number = {1},
	journaltitle = {Oxford Review of Economic Policy},
	shortjournal = {Oxf Rev Econ Policy},
	author = {Amable, Bruno},
	urldate = {2026-02-19},
	date = {2009-03-01},
	file = {Full Text PDF:C\:\\Users\\gueney\\Zotero\\storage\\USWBAMK8\\Amable - 2009 - Structural reforms in Europe and the (in)coherence of institutions.pdf:application/pdf},
}

