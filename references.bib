	langid = {english},
	keywords = {Greece, Italy, consistent models, empirical stock–flow},
	file = {Full Text PDF:C\:\\Users\\gueney\\Zotero\\storage\\IRI3WV5A\\Zezza et Zezza - 2019 - On the design of empirical stock–flow consistent models.pdf:application/pdf},
}

@article{stockhammer_update_2019,
