@article{cauvel_neo-goodwinian_2023,
	title = {The neo-Goodwinian model reconsidered},
	volume = {20},
	issn = {2052-7764, 2052-7772},
	url = {https://www.elgaronline.com/view/journals/ejeep/20/2/article-p183.xml},
	doi = {10.4337/ejeep.2022.0085},
	abstract = {This paper examines the relationship between aggregate demand and the wage share in the {US} using a vector autoregression methodology. It finds evidence of Goodwin-cycle effects – that is, profit-led demand and a profit-squeeze effect – in baseline estimates using assumptions traditionally used in the aggregative literature. However, estimates that examine the relationship between demand and the two components of the wage share (the real wage rate and labor productivity) indicate that these results are highly sensitive to ordering restrictions relating demand and labor productivity and that different types of shocks to the wage share may have differing effects on demand. The results suggest two possible interpretations of the initial Goodwin-cycle finding, depending on the assumptions used to identify the demand–productivity relationship. One suggests that the initial estimates reflect a causal relationship in which the effects are driven by a positive effect of productivity on demand and a negative effect of demand on productivity. The other suggests that the initial Goodwin-cycle finding may be spurious, as it interprets contemporaneous pro-cyclical variation in labor productivity as a profit-led demand effect, thereby obscuring an underlying wage-led relationship.},
	pages = {183--246},
	number = {2},
	journaltitle = {European Journal of Economics and Economic Policies},
	publisher = {Edward Elgar Publishing Ltd},
	author = {Cauvel, Michael},
	urldate = {2025-12-16},
	date = {2023-11-20},
	langid = {english},
	keywords = {E12, E25, wage-led and profit-led demand regimes, E11, E32, functional distribution of income, neo-Kaleckian model},
	file = {Full Text PDF:C\:\\Users\\gueney\\Zotero\\storage\\X8HT3IKS\\Cauvel - 2023 - The neo-Goodwinian model reconsidered.pdf:application/pdf},
}

@article{akcay_growth_2023,
