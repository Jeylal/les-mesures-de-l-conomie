	langid = {english},
	keywords = {E12, E10, E17, empirical macrostructural models, empirical stock–flow consistent, stock–flow consistent modelling},
	file = {Full Text PDF:C\:\\Users\\gueney\\Zotero\\storage\\86AMVYWF\\Pierros - 2025 - Empirical stock–flow consistent models evolution, current state and prospects.pdf:application/pdf},
