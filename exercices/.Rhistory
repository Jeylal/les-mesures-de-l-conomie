library(rdbnomics)
library(tidyverse)
data <- rdb(ids = "AMECO/ALCD0/CHE.1.0.0.0.ALCD0")
View(data)
data <- rdb(ids = "AMECO/ALCD0/CHE.1.0.0.0.ALCD0") %>%
select(original_value, value)
View(data)
View(data)
data <- rdb(ids = "AMECO/ALCD0/CHE.1.0.0.0.ALCD0") %>%
select(original_period, value) %>%
drop_na()
View(data)
data <- rdb(ids = "AMECO/ALCD0/CHE.1.0.0.0.ALCD0") %>%
select(original_period, value) %>%
drop_na() %>%
rename(
year = original_period,
part_salaire_ameco = value
)
View(data)
data %>%
ggplot(aes(x = year, y = part_salaire_ameco))+
geom_line()
glimpse(data)
data <- rdb(ids = "AMECO/ALCD0/CHE.1.0.0.0.ALCD0") %>%
select(original_period, value) %>%
drop_na() %>%
rename(
year = original_period,
part_salaire_ameco = value
) %>%
as.numeric()
data$year = as.numeric(data$year)
data %>%
ggplot(aes(x = year, y = part_salaire_ameco))+
geom_line()
